{
  "name": "@eichho/fauna",
  "version": "2.0.13",
  "description": "Fauna — AI assistant CLI. Chat with LLMs, run autonomous tasks, and control your desktop from the terminal.",
  "author": {
    "name": "Solomon Abey",
    "email": "solomonoabey@gmail.com",
    "url": "https://github.com/howmon"
  },
  "license": "MIT",
  "type": "module",
  "main": "main.js",
  "bin": {
    "fauna": "./cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/howmon/fauna.git"
  },
  "homepage": "https://github.com/howmon/fauna#readme",
  "keywords": [
    "ai",
    "cli",
    "assistant",
    "llm",
    "agent",
    "openai",
    "gpt",
    "chat",
    "tasks",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare:relay": "npm --prefix relay ci --omit=dev --no-audit --no-fund",
    "start": "electron .",
    "cli": "node cli.js",
    "serve": "node cli.js --server",
    "dev": "electron . --inspect",
    "prebuild": "npm run prepare:relay",
    "build": "node -e \"const fs=require('fs');for(const d of ['dist/mac','dist/mac-arm64'])fs.rmSync(d,{recursive:true,force:true})\" && electron-builder --mac --dir",
    "build:unsigned": "node -e \"const fs=require('fs');for(const d of ['dist/mac','dist/mac-arm64'])fs.rmSync(d,{recursive:true,force:true})\" && electron-builder --mac --dir -c.mac.identity=null",
    "predist": "npm run prepare:relay",
    "dist": "electron-builder --mac",
    "predist:mac": "npm run prepare:relay",
    "dist:mac": "electron-builder --mac --arm64",
    "predist:win": "npm run prepare:relay",
    "dist:win": "electron-builder --win",
    "predist:all": "npm run prepare:relay",
    "dist:all": "electron-builder --mac --win",
    "postdist:mac": "npm rebuild keytar --arch=arm64",
    "version:show": "node scripts/version.cjs",
    "version:patch": "node scripts/version.cjs patch",
    "version:minor": "node scripts/version.cjs minor",
    "version:major": "node scripts/version.cjs major",
    "version:set": "node scripts/version.cjs set",
    "release:check": "node scripts/validate-release.cjs",
    "gen:capabilities": "node scripts/gen-capabilities.cjs"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.5",
    "@playwright/mcp": "^0.0.73",
    "@softeria/ms-365-mcp-server": "^0.114.0",
    "@xenova/transformers": "^2.0.1",
    "archiver": "^7.0.1",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "js-tiktoken": "^1.0.21",
    "kokoro-js": "^1.2.1",
    "localtunnel": "^2.0.2",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "openai": "^6.45.0",
    "pdf-to-img": "^6.1.0",
    "playwright-core": "^1.58.2",
    "qrcode": "^1.5.4",
    "sherpa-onnx-node": "^1.13.3",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "41.10.2",
    "electron-builder": "^26.15.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "localtunnel": {
      "axios": "^1.12.2"
    }
  },
  "build": {
    "appId": "com.fauna.app",
    "productName": "Fauna",
    "afterPack": "./afterPack.cjs",
    "afterSign": "./afterSign.cjs",
    "copyright": "Copyright © 2026 Solomon Abey",
    "icon": "assets/icon.icns",
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/@playwright/mcp/**",
      "node_modules/playwright-core/**",
      "node_modules/playwright/**",
      "node_modules/@microsoft/workiq/**",
      "node_modules/@softeria/ms-365-mcp-server/**",
      "node_modules/kokoro-js/**",
      "node_modules/@huggingface/transformers/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/onnxruntime-common/**",
      "node_modules/onnxruntime-web/**",
      "node_modules/sherpa-onnx-node/**",
      "node_modules/sherpa-onnx-*/**",
      "fauna-bot/server/**",
      "fauna-bot/node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "icon": "assets/icon.icns",
      "identity": "318580CBB9288DC0C5A72DA6F25F1DB983CFB20A",
      "notarize": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "hardenedRuntime": true,
      "extendInfo": {
        "NSDownloadsFolderUsageDescription": "Fauna needs access to projects you open or create in Downloads.",
        "NSDocumentsFolderUsageDescription": "Fauna needs access to projects you open or create in Documents.",
        "NSDesktopFolderUsageDescription": "Fauna needs access to projects you open or create on the Desktop."
      }
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fauna"
    },
    "dmg": {
      "title": "Fauna",
      "icon": "assets/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "*.js",
      "*.cjs",
      "server/**",
      "lib/**",
      "skills/**",
      "public/**",
      "assets/**",
      "fauna-bot/server/**",
      "fauna-bot/manifest.json",
      "fauna-bot/color.png",
      "fauna-bot/outline.png",
      "fauna-bot/package.json",
      "fauna-bot/node_modules/**",
      "package.json",
      "!node_modules/@xenova/transformers/**",
      "node_modules/@xenova/transformers/dist/transformers.min.js",
      "node_modules/@xenova/transformers/dist/ort-wasm-simd-threaded.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm-simd.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm-threaded.wasm"
    ],
    "electronVersion": "41.10.2",
    "extraResources": [
      {
        "from": "assets/figma-plugin",
        "to": "figma-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/server",
        "to": "mcp-server/server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/node_modules",
        "to": "mcp-server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/package.json",
        "to": "mcp-server/package.json"
      },
      {
        "from": "browser-extension",
        "to": "browser-extension",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
