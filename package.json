{
  "name": "@eichho/fauna",
  "version": "2.0.0",
  "description": "Fauna — AI assistant CLI. Chat with LLMs, run autonomous tasks, and control your desktop from the terminal.",
  "author": {
    "name": "Solomon Abey",
    "email": "solomonoabey@gmail.com",
    "url": "https://github.com/howmon"
  },
  "license": "MIT",
  "type": "module",
  "main": "main.js",
  "bin": {
    "fauna": "./cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/howmon/fauna.git"
  },
  "homepage": "https://github.com/howmon/fauna#readme",
  "keywords": [
    "ai",
    "cli",
    "assistant",
    "llm",
    "agent",
    "openai",
    "gpt",
    "chat",
    "tasks",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare:relay": "npm --prefix relay ci --omit=dev --no-audit --no-fund",
    "build:whisper": "node -e \"const fs=require('fs'),cp=require('child_process'),p=require('path');if(process.platform==='win32'){console.log('[whisper] skipping native whisper.cpp build on Windows');process.exit(0)}const d=p.join('node_modules','nodejs-whisper','cpp','whisper.cpp');const bin=p.join(d,'build','bin','whisper-cli');if(fs.existsSync(bin)){console.log('[whisper] whisper-cli already built');process.exit(0)}if(!fs.existsSync(d)){console.error('[whisper] nodejs-whisper not installed');process.exit(0)}console.log('[whisper] building whisper.cpp via cmake...');cp.execSync('cmake -B build',{cwd:d,stdio:'inherit'});cp.execSync('cmake --build build --config Release -j',{cwd:d,stdio:'inherit'});\"",
    "start": "electron .",
    "cli": "node cli.js",
    "serve": "node cli.js --server",
    "dev": "electron . --inspect",
    "prebuild": "npm run prepare:relay && npm run build:whisper",
    "build": "electron-builder --mac --dir",
    "predist": "npm run prepare:relay && npm run build:whisper",
    "dist": "electron-builder --mac",
    "predist:mac": "npm run prepare:relay && npm run build:whisper",
    "dist:mac": "electron-builder --mac --arm64",
    "predist:win": "npm run prepare:relay && npm run build:whisper",
    "dist:win": "electron-builder --win",
    "predist:all": "npm run prepare:relay && npm run build:whisper",
    "dist:all": "electron-builder --mac --win",
    "postdist:mac": "npm rebuild keytar --arch=arm64",
    "version:show": "node scripts/version.cjs",
    "version:patch": "node scripts/version.cjs patch",
    "version:minor": "node scripts/version.cjs minor",
    "version:major": "node scripts/version.cjs major",
    "version:set": "node scripts/version.cjs set"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.5",
    "@playwright/mcp": "^0.0.73",
    "@softeria/ms-365-mcp-server": "^0.99.1",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "kokoro-js": "^1.2.1",
    "localtunnel": "^2.0.2",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "nodejs-whisper": "^0.3.0",
    "openai": "^4.67.0",
    "playwright-core": "^1.58.2",
    "qrcode": "^1.5.4",
    "turndown": "^7.2.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "com.fauna.app",
    "productName": "Fauna",
    "afterPack": "./afterPack.cjs",
    "copyright": "Copyright © 2026 Solomon Abey",
    "icon": "assets/icon.icns",
    "asarUnpack": [
      "node_modules/nodejs-whisper/**",
      "node_modules/ffmpeg-static/**",
      "node_modules/@playwright/mcp/**",
      "node_modules/playwright-core/**",
      "node_modules/playwright/**",
      "node_modules/@microsoft/workiq/**",
      "node_modules/@softeria/ms-365-mcp-server/**",
      "fauna-bot/server/**",
      "fauna-bot/node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "icon": "assets/icon.icns",
      "identity": "318580CBB9288DC0C5A72DA6F25F1DB983CFB20A",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fauna"
    },
    "dmg": {
      "title": "Fauna",
      "icon": "assets/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "*.js",
      "*.cjs",
      "server/**",
      "lib/**",
      "public/**",
      "assets/**",
      "fauna-bot/server/**",
      "fauna-bot/manifest.json",
      "fauna-bot/color.png",
      "fauna-bot/outline.png",
      "fauna-bot/package.json",
      "fauna-bot/node_modules/**",
      "package.json",
      "node_modules/**",
      "!node_modules/@xenova/transformers/**",
      "node_modules/@xenova/transformers/dist/transformers.min.js",
      "node_modules/@xenova/transformers/dist/ort-wasm-simd-threaded.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm-simd.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm.wasm",
      "node_modules/@xenova/transformers/dist/ort-wasm-threaded.wasm",
      "node_modules/nodejs-whisper/dist/**",
      "node_modules/nodejs-whisper/cpp/whisper.cpp/build/**",
      "!node_modules/nodejs-whisper/cpp/whisper.cpp/models/**"
    ],
    "electronVersion": "41.0.3",
    "extraResources": [
      {
        "from": "assets/figma-plugin",
        "to": "figma-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/server",
        "to": "mcp-server/server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/node_modules",
        "to": "mcp-server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "relay/package.json",
        "to": "mcp-server/package.json"
      },
      {
        "from": "browser-extension",
        "to": "browser-extension",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
