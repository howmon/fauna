{
  "expo": {
    "name": "Fauna Mobile",
    "slug": "fauna-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fauna",
    "splash": {
      "backgroundColor": "#1b1b1b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fauna.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Fauna needs camera access to scan QR codes and take photos for conversations.",
        "NSPhotoLibraryUsageDescription": "Fauna needs photo library access to attach images to conversations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1b1b1b"
      },
      "usesCleartextTraffic": true,
      "package": "com.fauna.mobile",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Fauna to scan QR codes for pairing."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fauna to access photos for uploading images to conversations.",
          "cameraPermission": "Allow Fauna to take photos for uploading to conversations."
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "585cd5a9-4487-4a59-8a1a-2bf043dfc771"
      }
    },
    "owner": "howmon"
  }
}
