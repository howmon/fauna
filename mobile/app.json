{
  "expo": {
    "name": "Fauna Mobile",
    "slug": "fauna-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fauna",
    "splash": {
      "backgroundColor": "#1b1b1b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fauna.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Fauna needs camera access to scan QR codes for pairing with your desktop server."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1b1b1b"
      },
      "package": "com.fauna.mobile",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow Fauna to scan QR codes for pairing." }]
    ]
  }
}
