{
  "expo": {
    "name": "Fauna Mobile",
    "slug": "fauna-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "fauna",
    "splash": {
      "backgroundColor": "#1b1b1b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fauna.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Fauna needs camera access to scan QR codes for pairing with your desktop server."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1b1b1b"
      },
      "usesCleartextTraffic": true,
      "package": "com.fauna.mobile",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Fauna to scan QR codes for pairing."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "585cd5a9-4487-4a59-8a1a-2bf043dfc771"
      }
    },
    "owner": "howmon"
  }
}
