{
  "manifest_version": 3,
  "name":        "FaunaBrowserMCP",
  "version":     "1.1.0",
  "description": "Bridges your browser to the FaunaBrowserMCP relay so AI agents can read and control browser tabs.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "windows",
    "sidePanel",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],

  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "MacCtrl+Shift+M"
      },
      "description": "Open/close the FaunaBrowserMCP sidebar"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [{
    "matches":  ["<all_urls>"],
    "js":       ["content.js"],
    "run_at":   "document_idle",
    "all_frames": false
  }],

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open FaunaBrowserMCP Sidebar"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
