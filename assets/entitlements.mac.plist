<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Required for Electron's JIT compiler (V8) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Required for Electron renderer processes -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allows loading native Node modules (express, openai, etc.) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Outbound HTTP/HTTPS — GitHub Copilot API, URL fetching -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Send Apple Events to other apps (Finder, app switching, AppleScript automation) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
  </dict>
</plist>
