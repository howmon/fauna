{
  "manifest_version": 3,
  "name":        "FaunaBrowserMCP",
  "version":     "1.0.0",
  "description": "Bridges your browser to the FaunaBrowserMCP relay so AI agents can read and control browser tabs.",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [{
    "matches":  ["<all_urls>"],
    "js":       ["content.js"],
    "run_at":   "document_idle",
    "all_frames": false
  }],

  "action": {
    "default_popup": "popup.html",
    "default_title": "FaunaBrowserMCP"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
