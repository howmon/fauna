{
  "name": "faunafigmamcp",
  "version": "1.0.0",
  "description": "FaunaFigmaMCP — Figma MCP relay tray utility. Bridges the Fauna Figma plugin to any MCP-capable AI tool.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.fauna.figma.mcp",
    "productName": "FaunaFigmaMCP",
    "copyright": "Copyright © 2026 Solomon Abey",
    "publish": null,
    "files": [
      "main.js",
      "preload.js",
      "popup.html"
    ],
    "extraResources": [
      {
        "from": "../assets/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../assets/icon.icns",
        "to": "icon.icns"
      },
      {
        "from": "../assets/figma-plugin",
        "to": "figma-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../relay/server",
        "to": "mcp-server/server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../relay/node_modules",
        "to": "mcp-server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../relay/package.json",
        "to": "mcp-server/package.json"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "../assets/icon.icns",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "../assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "FaunaFigmaMCP",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "electronVersion": "41.0.3"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
